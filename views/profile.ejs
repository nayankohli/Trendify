<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="fonts/material-icon/css/material-design-iconic-font.min.css">
    <link rel="stylesheet" href="/css/all.min.css"> <!-- Font Awesome CSS -->
  <link rel="stylesheet" href="/css/styles.css"> 
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" integrity="sha512-WJ5zFGpLqYgsa62uRg2P6Xszpsk1cM/jzNKHzxoUGK5Te2SdDufNwkqj5OEx59upj9JtnMO0t9nN2/xDxSZJjA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" integrity="sha512-WJ5zFGpLqYgsa62uRg2P6Xszpsk1cM/jzNKHzxoUGK5Te2SdDufNwkqj5OEx59upj9JtnMO0t9nN2/xDxSZJjA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        body{
            background-color:  #0A1627; 
            background-image: url(./logo-color.png);
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-repeat: no-repeat;
            background-size: 70%;
            background-attachment: fixed;
            background-position: center;
            z-index: -2;
        }
        .gradient-custom {
            /* fallback for old browsers */
            background-color: #c9c7c7;
            border: 2px solid #0cd1f476;

        }

        .container-box {
            display: flex;
            flex-direction: row;
            width: 900px;
            background-color: rgba(255, 255, 255, 0.13);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            
        }

        .left-half {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .right-half {
            flex: 1;
            display: flex;
        }

        .card {
            display: flex;
            flex-direction: row;
            overflow: hidden;
            max-width: 1000px;
            background: #fff;/* Add padding for spacing */
            box-shadow: 0px 15px 16.83px 0.17px rgba(0, 0, 0, 0.05);
            border-radius: 20px;
            padding: 20px;
            background-color: rgba(255, 255, 255, 0.13);
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 0 40px rgba(8, 7, 16, 0.6);
        }

        
        .right-half {
            flex-basis: 60%;
            align-items: center;
            justify-content: center;
        }
        .left-half{
            flex-basis: 40%;
            border-radius: 20px;
        }
        .vh-100 {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .card-body {
            padding: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .container {
            padding: 2rem;
        }

        /* New CSS for buttons */
        .btn-row {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            width: 100%;
        }

        .btn-custom {
            background-color: #db234b;
            border: none;
            color: white;
            padding: 20px 40px;
            text-align: center;
            text-decoration: none;
            display: inline-block;
            font-size: 28px;
            border-radius: 40px;
            transition: background-color 0.3s ease;
            width: 100%; /* Full width of the parent */
            font-family: cursive;
        }

        .btn-custom:hover {
            background-color: rgba(255, 255, 255, 0.13);
            backdrop-filter: blur(10px);
            color:  #FE0039;
            border: 2px solid #FE0039;
            transform: scale(1.125);  
            filter: drop-shadow(0 10px 5px rgba(0,0,0,0.125));
            transition: all .3s ease;
        }
        .card-body h2{
            font-size: 50px;
            font-weight: 30px;
            color: #fff;
            margin-top: 10px;
            border-bottom: 4px solid #FE0039;
            font-family: cursive;
        }
        i{
            color: #0A1627;
            font-size: 20px;
        }
    </style>
</head>
<body>
    <section class="vh-100">
        <div class="container">
            <div class="row d-flex justify-content-center align-items-center h-100">
                <div class="col-md-8 col-lg-6 col-xl-4">
                    <div class="card">
                        <div class="container-box">
                            <div class="left-half gradient-custom text-center text-white">
                                <div>
                                    <img src="https://mdbcdn.b-cdn.net/img/Photos/new-templates/bootstrap-chat/ava1-bg.webp"
                                        alt="Avatar" class="img-fluid my-5" style="width: 80px;" />
                                    <h5>Marie Horwitz</h5>
                                    <p>Web Designer</p>
                                    <i class="far fa-edit mb-5"></i>
                                </div>
                            </div>
                            <div class="right-half">
                                <div class="card-body">
                                    <h2>My Profile</h2>
                                    <div class="btn-container">
                                        <div class="btn-row">
                                            <a href="/orders"><button class="btn-custom" ><i class="fa-solid fa-list"></i>  Orders</button></a>
                                            <a href="/heart"><button class="btn-custom"><i class="fa-solid fa-heart"></i>  Wishlist</button></a>
                                        </div>
                                        <div class="btn-row">
                                            <a href="/cart"><button class="btn-custom" ><i class="fa-solid fa-cart-shopping"></i>  Cart</button></a>
                                            <a href="/my"><button class="btn-custom"><i class="fa-solid fa-gears"></i>  Settings</button></a>
                                        </div>
                                        <div class="btn-row">
                                            <a href="/logout"><button class="btn-custom"><i class="fa-solid fa-right-from-bracket"></i>  Logout</button></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</body>
</html>
